# Grace Irvine Ministry Scheduler - 环境变量配置
# ================================================
# 复制此文件为 .env 并填入实际值

# Google Sheets 配置
# 从Google Sheets URL中获取ID
# 例如: https://docs.google.com/spreadsheets/d/YOUR_ID_HERE/edit
GOOGLE_SPREADSHEET_ID=1wescUQe9rIVLNcKdqmSLpzlAw9BGXMZmkFvjEF296nM

# 邮件发送配置
# ================================================

# 发件人邮箱地址
SENDER_EMAIL=jonathanjing@graceirvine.org

# 发件人显示名称
SENDER_NAME=Grace Irvine 事工协调

# Gmail应用专用密码（不是账户密码！）
# 获取方法：
# 1. 访问 https://myaccount.google.com/security
# 2. 启用两步验证
# 3. 访问 https://myaccount.google.com/apppasswords
# 4. 选择"邮件"和"其他"，输入"Grace Irvine Ministry"
# 5. 复制生成的16位密码到这里（不要包含空格）
EMAIL_PASSWORD=your_16_digit_app_password_here

# SMTP服务器配置（默认为Gmail）
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# 收件人邮箱列表（可选）
# 多个邮箱用逗号分隔，例如: email1@example.com,email2@example.com
# 如果不设置，默认会发送给发件人自己（用于测试）
RECIPIENT_EMAILS=

# 其他可选配置
# ================================================

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 是否启用测试模式（只显示不发送）
TEST_MODE=false

# 时区设置
TIMEZONE=America/Los_Angeles
