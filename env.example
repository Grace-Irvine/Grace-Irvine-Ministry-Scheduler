# Grace Irvine Ministry Scheduler Environment Variables

# Application Settings
DEBUG=false
API_KEY=your_secure_api_key_here

# Google Sheets Configuration
GOOGLE_SPREADSHEET_ID=your_google_spreadsheet_id_here
# Service account JSON file should be placed in configs/service_account.json

# Email Configuration (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@graceirvine.org
SENDGRID_FROM_NAME=Grace Irvine Ministry

# Email Configuration (SMTP Backup)
SMTP_HOST=smtp.gmail.com
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# SMS Configuration (AWS SNS Alternative)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# Calendar Configuration
CALENDAR_BASE_URL=https://your-domain.com/calendars

# Recipients Configuration
# Primary notification recipients
PRIMARY_EMAIL_1=coordinator@graceirvine.org
PRIMARY_PHONE_1=+1234567890
PRIMARY_EMAIL_2=worship@graceirvine.org
PRIMARY_PHONE_2=+1234567891

# Backup recipients
BACKUP_EMAIL_1=pastor@graceirvine.org

# Redis Configuration (for background tasks)
REDIS_URL=redis://localhost:6379/0

# Database Configuration (if using PostgreSQL instead of SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/ministry_scheduler

# Deployment Configuration
# For Google Cloud Run deployment
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1
CLOUD_RUN_SERVICE_NAME=ministry-scheduler

# Monitoring and Logging
LOG_LEVEL=INFO
SENTRY_DSN=your_sentry_dsn_here  # Optional: for error tracking

# Security
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
CORS_ORIGINS=https://your-domain.com,http://localhost:3000

# Feature Flags
ENABLE_WEB_UI=true
ENABLE_API=true
ENABLE_WEBHOOKS=false
ENABLE_ANALYTICS=false
